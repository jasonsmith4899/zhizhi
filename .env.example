# ════════════════════════════════════════════════════════════════
# 智知 AI 知识库 - 环境配置模板（.env.example）
# 说明：复制本文件为 .env，然后填入实际的配置值
# 重要：.env 文件包含敏感信息，不要提交到 Git
# ════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════
# 【数据库配置】
# ════════════════════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zhizhi
DB_USER=postgres
DB_PASSWORD=your_secure_postgres_password_here

# ════════════════════════════════════════════════════════════════
# 【AI 模型配置】
# ════════════════════════════════════════════════════════════════

# DeepSeek Chat API（LLM 模型）
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# SiliconFlow API（Embedding + Reranker 模型）
SILICONFLOW_API_KEY=sk-your_siliconflow_api_key_here
EMBEDDING_BASE_URL=https://api.siliconflow.cn
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_BASE_URL=https://api.siliconflow.cn
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ════════════════════════════════════════════════════════════════
# 【认证配置】
# ════════════════════════════════════════════════════════════════

# JWT 密钥（用于签名 token，必须足够长）
JWT_SECRET=your_jwt_secret_key_must_be_long_enough_32_chars_or_more!

# ════════════════════════════════════════════════════════════════
# 【微信小程序配置】
# ════════════════════════════════════════════════════════════════
WECHAT_APPID=your_wechat_app_id_here
WECHAT_SECRET=your_wechat_app_secret_here

# ════════════════════════════════════════════════════════════════
# 【应用配置】
# ════════════════════════════════════════════════════════════════
APP_PORT=8080
APP_PROFILE=dev

# ════════════════════════════════════════════════════════════════
# 【日志配置】
# ════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
