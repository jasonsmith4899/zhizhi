# 智知 AI 知识库 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值: cp .zhizhi/.env.example .zhizhi/.env

# ========== 数据库 ==========
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zhizhi
DB_USER=postgres
DB_PASSWORD=your-database-password-here

# ========== AI 服务 ==========
DEEPSEEK_API_KEY=your-deepseek-api-key-here
SILICONFLOW_API_KEY=your-siliconflow-api-key-here

# ========== 安全 ==========
# JWT签名密钥（生产环境必须修改为随机强密钥）
JWT_SECRET=zhizhi-ai-knowledge-base-jwt-secret-key-2026

# ========== 微信小程序（可选） ==========
WECHAT_APPID=your-wechat-appid-here
WECHAT_SECRET=your-wechat-secret-here
