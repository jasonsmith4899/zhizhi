.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f7fa;
}

/* 聊天列表 */
.chat-list {
  flex: 1;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

/* 欢迎消息 */
.welcome-msg {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx 60rpx;
}

.welcome-icon {
  width: 120rpx;
  height: 120rpx;
  background: #e6f7ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.welcome-emoji {
  font-size: 60rpx;
}

.welcome-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
}

/* 消息项 */
.message-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.msg-right {
  flex-direction: row-reverse;
}

/* 头像 */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #1890ff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
}

.user-avatar {
  background: #52c41a;
}

.msg-right .avatar {
  margin-left: 16rpx;
}

.msg-left .avatar {
  margin-right: 16rpx;
}

/* 气泡包裹 */
.bubble-wrap {
  max-width: 75%;
  min-width: 100rpx;
}

/* 气泡 */
.bubble {
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  word-break: break-all;
  position: relative;
}

.bubble-user {
  background: #1890ff;
  color: #ffffff;
  border-top-right-radius: 4rpx;
}

.bubble-ai {
  background: #ffffff;
  color: #333333;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.bubble-error {
  background: #fff2f0;
  color: #ff4d4f;
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.7;
}

/* 加载动画 */
.bubble-loading {
  padding: 24rpx 36rpx;
}

.typing-dots {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #1890ff;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot1 {
  animation-delay: -0.32s;
}

.dot2 {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 来源引用 */
.sources-wrap {
  margin-top: 12rpx;
}

.sources-toggle {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.sources-label {
  font-size: 24rpx;
  color: #1890ff;
}

.sources-arrow {
  font-size: 28rpx;
  color: #1890ff;
  margin-left: 8rpx;
  transition: transform 0.2s;
  transform: rotate(90deg);
}

.arrow-up {
  transform: rotate(-90deg);
}

.sources-list {
  margin-top: 8rpx;
}

.source-item {
  background: #f0f8ff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 10rpx;
  border-left: 4rpx solid #1890ff;
}

.source-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.source-name {
  font-size: 22rpx;
  color: #1890ff;
  font-weight: 500;
}

.source-score {
  font-size: 20rpx;
  color: #999999;
  background: #e6f7ff;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.source-content {
  font-size: 22rpx;
  color: #666666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* 底部占位 */
.bottom-placeholder {
  height: 20rpx;
}

/* 输入区域 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #eeeeee;
}

.input-field {
  flex: 1;
  height: 72rpx;
  background: #f5f7fa;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #333333;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  background: #cccccc;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #ffffff;
  flex-shrink: 0;
}

.send-btn-active {
  background: #1890ff;
}

.send-btn-active:active {
  background: #096dd9;
}
