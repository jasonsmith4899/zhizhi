.page {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 会话列表 */
.conversation-list {
  padding: 20rpx 0;
}

.conversation-item {
  position: relative;
  overflow: hidden;
  margin-bottom: 2rpx;
}

.conversation-content {
  background: #ffffff;
  padding: 30rpx;
  transition: transform 0.2s;
}

.swiped .conversation-content {
  transform: translateX(-140rpx);
}

.conversation-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.conversation-title {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 20rpx;
}

.conversation-time {
  font-size: 24rpx;
  color: #999999;
  flex-shrink: 0;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background: #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  transform: translateX(0);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-spinner {
  font-size: 28rpx;
  color: #999999;
}
