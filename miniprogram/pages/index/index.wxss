.page {
  min-height: 100vh;
  background: #f5f7fa;
}

/* Banner */
.banner {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 60rpx 40rpx;
  margin: 0 0 30rpx 0;
}

.banner-content {
  display: flex;
  align-items: center;
}

.banner-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.icon-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.banner-text {
  flex: 1;
}

.banner-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.banner-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 区块 */
.section {
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

/* 操作卡片 */
.action-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.action-card:active {
  background: #f0f0f0;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.chat-icon {
  background: #e6f7ff;
}

.history-icon {
  background: #fff7e6;
}

.icon-emoji {
  font-size: 40rpx;
}

.action-info {
  flex: 1;
}

.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4rpx;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.action-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

/* 功能特点 */
.features {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.feature-item {
  width: calc(50% - 10rpx);
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.feature-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.feature-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.feature-desc {
  display: block;
  font-size: 22rpx;
  color: #999999;
  line-height: 1.4;
}

/* 登录状态 */
.login-status {
  text-align: center;
  padding: 40rpx;
}

.login-hint {
  font-size: 26rpx;
  color: #999999;
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-spinner {
  background: rgba(0, 0, 0, 0.7);
  border-radius: 16rpx;
  padding: 30rpx 50rpx;
  color: #ffffff;
  font-size: 28rpx;
}
